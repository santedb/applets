<ViewModel xmlns="http://santedb.org/model/view">
  <include>noModelProperties</include>

  <type type="MailMessage" all="true">
    <property name="fromModel" behavior="always"/>
    <property name="rcptModel" behavior="always" all="true">

    </property>
  </type>

  <type type="MailboxMailMessage">
    <property name="messageModel" behavior="always" />
  </type>

   <type type="Mailbox" all="true">
        <property name="ownerModel" behavior="always" />
        <property name="messages" behavior="never" />
    </type>
</ViewModel>